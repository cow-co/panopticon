{
  "name": "panopticon",
  "version": "0.0.1",
  "description": "A standalone tool to visualise your digital footprint",
  "main": "main.js",
  "scripts": {
    "test": "echo \"no test specified\"",
    "start": "electron .",
    "electron-start": "npm run build && electron .",
    "postinstall": "electron-builder install-app-deps && electron-rebuild",
    "preelectron-pack": "npm run build",
    "electron-pack": "electron-builder -c.extraMetadata.main=build/main.js",
    "release": "electron-builder -c.extraMetadata.main=build/main.js",
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cow-co/panopticon.git"
  },
  "build": {
    "productName": "PANOPTICON",
    "appId": "panopticonS",
    "files": [
      "build/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "publish": [
        "github"
      ]
    },
    "win": {
      "target": "NSIS",
      "publish": [
        "github"
      ]
    }
  },
  "author": "cow-co",
  "bugs": {
    "url": "https://github.com/cow-co/panopticon/issues"
  },
  "homepage": "https://github.com/cow-co/panopticon#readme",
  "devDependencies": {
    "electron": "^13.1.7",
    "electron-builder": "^22.11.7",
    "electron-rebuild": "^2.3.5",
    "@vue/cli-plugin-babel": "~4.5.0",
    "@vue/cli-plugin-eslint": "~4.5.0",
    "@vue/cli-service": "~4.5.0",
    "@vue/compiler-sfc": "^3.0.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^6.7.2",
    "eslint-plugin-vue": "^7.0.0"
  },
  "dependencies": {
    "core-js": "^3.6.5",
    "vue": "^3.0.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "babel-eslint"
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
